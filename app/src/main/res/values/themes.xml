<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme – Nothing OS monochrome dark -->
    <style name="Theme.MouseTouchLock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorBackground">@color/bg_app</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorPrimary">@color/text_primary</item>
        <item name="colorPrimaryVariant">@color/border_bright</item>
        <item name="colorOnPrimary">@color/bg_app</item>
        <item name="colorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_app</item>
        <item name="android:navigationBarColor">@color/bg_app</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

    <!-- ── Button styles using Material attributes (no android:background conflict) ── -->

    <!-- White filled button (primary action) -->
    <style name="NothingButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/text_primary</item>
        <item name="android:textColor">@color/bg_app</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">#33000000</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- White-outlined transparent button (secondary action) -->
    <style name="NothingButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/text_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Mini permission-row button -->
    <style name="BtnMini" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_bright</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">11sp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingRight">10dp</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>
